---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A blog inspired by national parks" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
</head>
<body>
  <header>
    <nav>
      <div class="nav-container">
        <a href="/twigs/" class="logo">Targy's Twigs</a>
        <ul class="nav-links">
          <li><a href="/twigs/">Home</a></li>
          <li><a href="/twigs/blog">Blogs</a></li>
          <li><a href="/twigs/about">About</a></li>
          <li><a href="/twigs/terms">Terms</a></li>
        </ul>
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>&copy; {new Date().getFullYear()} Targy's Twigs. One dog, infinite sticks, endless adventure.</p>
  </footer>
</body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&family=Merriweather:wght@400;700&display=swap');

  :root {
    --color-bg: #f5f1e8;
    --color-ink: #3d3530;
    --color-primary: #6b4423;
    --color-secondary: #9d7b54;
    --color-accent: #9d7b54;
    --color-muted: #8b7355;
    --color-border: #3d3530;
    --color-highlight: #a0663d;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Merriweather', serif;
    background-color: var(--color-bg);
    color: var(--color-ink);
    line-height: 1.6;
  }

  header {
    background-color: var(--color-primary);
    padding: 1rem 0;
    border-bottom: 4px solid var(--color-secondary);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 2rem;
    font-weight: bold;
    color: var(--color-bg);
    text-decoration: none;
    letter-spacing: 2px;
    font-family: 'Poppins', sans-serif;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--color-bg);
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: color 0.3s ease;
    position: relative;
    font-family: 'Poppins', sans-serif;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-accent);
    transition: width 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--color-accent);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0rem 2rem;
    min-height: calc(100vh - 200px);
  }

  footer {
    background-color: var(--color-primary);
    color: var(--color-bg);
    text-align: center;
    padding: 2rem;
    margin-top: 4rem;
    border-top: 4px solid var(--color-secondary);
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Poppins', sans-serif;
    color: var(--color-secondary);
    letter-spacing: 1px;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 3rem;
  }

  h2 {
    font-size: 2.2rem;
    border-bottom: 3px solid var(--color-accent);
    padding-bottom: 0.5rem;
  }

  a {
    color: var(--color-primary);
    transition: color 0.3s ease;
  }

  a:hover {
    color: var(--color-secondary);
  }

  @media (max-width: 768px) {
    .nav-container {
      flex-direction: column;
      gap: 1rem;
    }

    .logo {
      font-size: 1.5rem;
    }

    .nav-links {
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .nav-links a {
      font-size: 0.9rem;
    }

    main {
      padding: 0 1rem 2rem 1rem;
    }

    h1 {
      font-size: 2rem;
    }

    h2 {
      font-size: 1.6rem;
    }
  }
</style>
</style>
